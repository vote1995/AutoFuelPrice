# Line Messaging API credentials (required for notifications)
# Provide these to enable push messages; bot runs without them and just logs.
LINE_CHANNEL_TOKEN=
LINE_TARGET_ID=

# Optional: override the path where the last-known price snapshot is stored.
# Defaults to ./last_fuel_prices.json next to the working directory.
# STATE_FILE=/var/lib/auto_fuel_price/last_fuel_prices.json

# Optional: run a single tick immediately and exit (useful for cron/systemd
# timers or manual smoke tests). Leave unset for the built-in scheduler.
# RUN_ONCE=1

# Log filter directive — falls back to "info" when unset.
RUST_LOG=info
